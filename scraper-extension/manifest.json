{
  "manifest_version": 3,
  "name": "Mental Health Reddit Scraper",
  "version": "0.1.0",
  "description": "Collect Reddit posts from mental-health subreddits for the research pipeline.",
  "permissions": ["downloads", "storage", "unlimitedStorage"],
  "host_permissions": ["*://*.reddit.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mental Health Reddit Scraper"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
